{
  "name": "@roylet-gs/agent-monitor",
  "version": "0.1.23",
  "description": "CLI TUI tool for monitoring git worktrees and Claude Code agent status",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "am": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/roylet-gs/agent-monitor.git"
  },
  "files": [
    "dist/",
    "release-notes.json"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.tsx",
    "dev": "tsx --watch src/cli.tsx"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "commander": "^14.0.3",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "open": "^11.0.0",
    "react": "^18.3.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
